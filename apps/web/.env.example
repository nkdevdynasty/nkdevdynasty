# =============================================================================
# NKDevDynasty - Web App Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# For local dev with docker-compose (make db):
DATABASE_URL="postgresql://postgres:password@localhost:5432/nkdevdynasty"

# --- NextAuth ----------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-real-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Authentik SSO -----------------------------------------------------------
# Your Authentik instance base URL (e.g. https://auth.yourcollege.edu)
AUTHENTIK_URL="https://auth.example.com"
AUTHENTIK_ISSUER_URL="https://auth.example.com/application/o/nkdevdynasty/"
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""
# API token for server-side user management (create in Authentik admin > Tokens)
AUTHENTIK_API_TOKEN=""

# --- Docs (optional) --------------------------------------------------------
NEXT_PUBLIC_DOCS_URL="http://localhost:3001"
