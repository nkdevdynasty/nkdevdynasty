# =============================================================================
# NKDevDynasty - Web App Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp apps/web/.env.example apps/web/.env
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Use your own Supabase or local Postgres instance.
# Each team member should have their own database.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/nkdevdynasty"

# --- NextAuth ----------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Authentik SSO -----------------------------------------------------------
# Shared team Authentik instance. Ask the team lead for these values.
AUTHENTIK_URL="http://authentikserver-ugwog0sockwwkc8g0gscsg0s.89.167.10.11.sslip.io"
AUTHENTIK_ISSUER_URL="http://authentikserver-ugwog0sockwwkc8g0gscsg0s.89.167.10.11.sslip.io/application/o/nkdevdynasty-auth/"
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""
AUTHENTIK_API_TOKEN=""

# --- Docs (optional) ---------------------------------------------------------
NEXT_PUBLIC_DOCS_URL="http://localhost:3001"
