# =============================================================================
# NKDevDynasty — Production Stack Environment Variables
# =============================================================================
# Copy to .env and fill in the values:   cp .env.example .env
# =============================================================================

# --- Shared PostgreSQL -------------------------------------------------------
PG_USER=postgres
PG_PASSWORD=          # REQUIRED — set a strong password

# --- Authentik (SSO) ---------------------------------------------------------
# Generate: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=  # REQUIRED
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

# --- Strapi (CMS) ------------------------------------------------------------
STRAPI_PORT=1337

# --- Web App (uncomment when deploying) --------------------------------------
# AUTH_SECRET=         # Generate: openssl rand -base64 32
# WEB_PORT=3000
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
# AUTHENTIK_API_TOKEN=
